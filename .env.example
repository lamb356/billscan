# ─── Database ────────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://billscan-yourusername.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ─── Authentication (NextAuth) ───────────────────────────────
NEXTAUTH_SECRET=generate-a-random-string-here
NEXTAUTH_URL=https://billscan.vercel.app

# Google OAuth (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (https://github.com/settings/developers → OAuth Apps)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Stripe Billing (https://dashboard.stripe.com) ──────────
STRIPE_SECRET_KEY=sk_test_or_sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_test_or_pk_live_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
