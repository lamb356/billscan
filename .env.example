# ─── BillScan Environment Variables ───────────────────────────────────────────

# Server
PORT=3000
APP_URL=https://billscan.app

# Database (Turso / libSQL)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Authentication
JWT_SECRET=replace-with-a-random-64-char-hex-string

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (SMTP)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=noreply@billscan.app
EMAIL_PASS=your-smtp-password
EMAIL_FROM=noreply@billscan.app

# Admin
ADMIN_EMAIL=burbach7@outlook.com
