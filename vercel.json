{
  "version": 2,
  "builds": [
    {
      "src": "src/server.ts",
      "use": "@vercel/node"
    },
    {
      "src": "web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "src/server.ts" },
    { "src": "/sitemap.xml", "dest": "web/sitemap.xml" },
    { "src": "/robots.txt", "dest": "web/robots.txt" },
    { "src": "/(.*)", "dest": "web/$1" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
